# Base de datos PostgreSQL. En Railway se crea al añadir el plugin Postgres.
DATABASE_URL="postgresql://user:password@host:5432/database"

# Secreto largo para firmar la sesión del admin. Genera uno nuevo antes de producción.
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL pública final de Railway o del dominio propio.
BASE_URL="http://localhost:3000"

# Admin inicial creado por el seed. No subas la contraseña real a GitHub.
ADMIN_SEED_EMAIL="info@marquee.es"
ADMIN_SEED_PASSWORD="pon-aqui-una-contrasena-segura-en-railway"

# Apple Wallet. Opcional hasta tener certificados reales.
APPLE_PASS_TYPE_ID=""
APPLE_TEAM_ID=""
APPLE_CERT_PATH=""
APPLE_KEY_PATH=""
APPLE_WWDR_CERT_PATH=""
APPLE_KEY_PASSWORD=""

# Google Wallet. Opcional hasta activar Google Wallet API.
GOOGLE_WALLET_ISSUER_ID=""
GOOGLE_WALLET_CLASS_ID=""
GOOGLE_APPLICATION_CREDENTIALS=""
